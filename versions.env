# Pinned toolchain versions. Every CI job reads this file, so a bump is one
# edit here and CI proves it everywhere at once.
#
# GO is the toolchain hebi is built with. CPYTHON is the compiled-tier
# interpreter and, from M8, the embedded host. PYPY runs the portability smoke
# over the emitted code so the compiled tier can never quietly assume CPython.
GO=1.26.5
CPYTHON=3.14.6
PYPY=3.11
